{
  "name": "sbox-monorepo",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev:web": "pnpm --filter @sbox/web dev",
    "build:web": "pnpm --filter @sbox/web build",
    "preview:web": "pnpm --filter @sbox/web preview",
    "dev": "pnpm --filter @sbox/app dev",
    "dev:app": "pnpm --filter @sbox/app dev",
    "build:app": "pnpm --filter @sbox/app windows:build",
    "tauri": "pnpm --filter @sbox/app tauri",
    "release": "node scripts/release.cjs",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitepress": "^1.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
