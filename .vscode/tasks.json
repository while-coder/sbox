{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ui:dev",
      "type": "shell",
      "isBackground": true,
      "command": "pnpm",
      "args": ["vite", "dev", "--port", "1421"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "(ready in|Local:).*"
        }
      }
    },
    {
      "label": "ui:build",
      "type": "shell",
      "command": "pnpm",
      "args": ["vite", "build"],
      "options": { "cwd": "${workspaceFolder}" }
    }
  ]
}
